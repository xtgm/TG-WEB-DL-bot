{
  "name": "tg-dualbot-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "node --check worker.js && node --check functions/[[path]].js",
    "test:fingerprint": "node tests/fingerprint_similarity.test.mjs",
    "test:fingerprint-schema": "node tests/fingerprint_schema.test.mjs",
    "test:verification-client": "node tests/verification_client_script.test.mjs",
    "test:log-translation": "node tests/log_translation.test.mjs",
    "test:topic-isolation": "node tests/topic_isolation.test.mjs",
    "db:apply": "wrangler d1 execute tg-dualbot-db --file=./migrations/0001_initial.sql --remote",
    "db:upgrade:verification": "wrangler d1 execute tg-dualbot-db --file=./migrations/0002_verification_gate.sql --remote",
    "db:upgrade:topics": "wrangler d1 execute tg-dualbot-db --file=./migrations/0003_topic_mode.sql --remote",
    "db:upgrade:fingerprint": "wrangler d1 execute tg-dualbot-db --file=./migrations/0004_device_fingerprint.sql --remote",
    "db:upgrade:webrtc-identity": "wrangler d1 execute tg-dualbot-db --file=./migrations/0005_webrtc_identity.sql --remote",
    "db:upgrade:fingerprint-similarity": "wrangler d1 execute tg-dualbot-db --file=./migrations/0006_fingerprint_similarity.sql --remote",
    "pages:deploy": "wrangler pages deploy public --project-name tg-dualbot-cloudflare"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
