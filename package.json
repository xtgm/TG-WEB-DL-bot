{
  "name": "tg-dualbot-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "node --check worker.js && node --check functions/[[path]].js",
    "db:apply": "wrangler d1 execute tg-dualbot-db --file=./migrations/0001_initial.sql --remote",
    "db:upgrade:verification": "wrangler d1 execute tg-dualbot-db --file=./migrations/0002_verification_gate.sql --remote",
    "pages:deploy": "wrangler pages deploy public --project-name tg-dualbot-cloudflare"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
